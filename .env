# --- Servidor ---
PORT=3000

# --- Base de datos ---
# Carpeta donde se guarda el archivo daylicio.db
# En Railway: apunta esto a la ruta de tu Volume persistente, ej: /data
DATA_DIR=./data

# --- Correo (SMTP) ---
# Si usas Gmail: activa verificación en 2 pasos en tu cuenta y genera una
# "Contraseña de aplicación" en https://myaccount.google.com/apppasswords
# NO uses tu contraseña normal de Gmail aquí.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=dayli-cio@gmail.com
SMTP_PASS=ayporchdxlcctese

# --- Horario del recordatorio automático ---
# Formato cron: minuto hora * * *  (hora del servidor)
# 0 21 * * *  = todos los días a las 9:00 PM
CRON_SCHEDULE=0 21 * * *

# --- Zona horaria (importante para que "hoy" y el cron sean correctos) ---
TZ=America/Havana
